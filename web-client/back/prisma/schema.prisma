generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String    @db.VarChar(50)
  lastName     String    @db.VarChar(50)
  password     String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  username     String?   @unique @db.VarChar(50)
  sessionToken String?   @db.VarChar(255)
  role         Role      @default(USER)
  birthDate    DateTime?
  gender       Gender?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime? @default(now()) @updatedAt
  deletedAt    DateTime?

  creditAccount CreditAccount?

  // Agentic Dev Maestro — domínio
  memberships    Membership[]
  assignedTasks  Task[]        @relation("TaskAssignee")
  authoredComments Comment[]   @relation("CommentAuthor")
  studyPlans     StudyPlan[]

  @@map("USERS")
}

model CreditAccount {
  id              Int                 @id @default(autoincrement())
  userId          Int                 @unique
  balance         Float               @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  lastDailyCredit DateTime?
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    CreditTransaction[]

  @@map("TB_CREDIT_ACCOUNT")
}

model CreditTransaction {
  id          Int             @id @default(autoincrement())
  accountId   Int
  type        TransactionType
  amount      Float
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime?       @updatedAt
  deletedAt   DateTime?
  account     CreditAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId], map: "TB_CREDIT_TRANSACTION_accountId_fkey")
  @@map("TB_CREDIT_TRANSACTION")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  email     String    @db.VarChar(255)
  token     String    @unique @db.VarChar(100)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("TB_PASSWORD_RESET_TOKENS")
}

model AppConfig {
  id          Int       @id @default(autoincrement())
  key         String    @unique(map: "key") @db.VarChar(100)
  value       String    @db.Text
  description String?   @db.VarChar(255)
  type        String?   @default("string") @db.VarChar(20)
  createdAt   DateTime? @default(now()) @db.DateTime(0)
  updatedAt   DateTime? @updatedAt @db.DateTime(0)

  @@map("TB_APP_CONFIG")
}

enum Role {
  USER
  ADMIN
  MANAGER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TransactionType {
  PURCHASE
  USAGE
  REFUND
}

// ===================================================================
// Agentic Dev Maestro — domínio (empresas, membros, API keys,
// projetos, quadros e tarefas). Ver docs/02-modelo-de-dados.md
// ===================================================================

model Company {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(120)
  slug        String       @unique @db.VarChar(120)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @updatedAt
  deletedAt   DateTime?
  memberships  Membership[]
  apiKeys      ApiKey[]
  projects     Project[]
  tasks        Task[]
  labels       Label[]
  documents    Document[]
  comments     Comment[]
  dependencies TaskDependency[]
  activityLogs ActivityLog[]
  webhooks     Webhook[]
  invitations  Invitation[]
  studyPlans   StudyPlan[]

  @@map("TB_COMPANY")
}

// Convite para entrar num workspace. Cobre quem ainda não tem conta:
// gera um token, a pessoa acessa o link, cria conta (ou faz login) e aceita,
// virando Membership. invitedByMembershipId é só para auditoria/exibição.
model Invitation {
  id                    Int            @id @default(autoincrement())
  companyId             Int
  email                 String         @db.VarChar(255)
  role                  MembershipRole @default(DEV)
  token                 String         @unique @db.VarChar(64) // sha-free: random hex
  invitedByMembershipId Int
  expiresAt             DateTime
  acceptedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime       @default(now())
  company               Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
  @@map("TB_INVITATION")
}

model Membership {
  id        Int            @id @default(autoincrement())
  userId    Int
  companyId Int
  role      MembershipRole @default(DEV)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  apiKeys   ApiKey[]

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("TB_MEMBERSHIP")
}

model ApiKey {
  id           Int        @id @default(autoincrement())
  label        String     @db.VarChar(120)
  hashedKey    String     @unique @db.VarChar(64) // sha256 hex do segredo
  prefix       String     @db.VarChar(16) // primeiros chars p/ exibir na UI
  scopes       Json?
  membershipId Int
  companyId    Int
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("TB_API_KEY")
}

model Project {
  id          Int       @id @default(autoincrement())
  companyId   Int
  name        String    @db.VarChar(120)
  key         String    @db.VarChar(20) // prefixo do código (ex.: "GAV")
  description String?   @db.Text
  taskSeq     Int       @default(0) // contador p/ numerar tarefas (GAV-1..n)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  deletedAt   DateTime?
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  boards      Board[]
  tasks       Task[]
  documents   Document[]

  @@unique([companyId, key])
  @@map("TB_PROJECT")
}

model Board {
  id        Int           @id @default(autoincrement())
  projectId Int
  name      String        @default("Principal") @db.VarChar(120)
  createdAt DateTime      @default(now())
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   BoardColumn[]

  @@index([projectId])
  @@map("TB_BOARD")
}

model BoardColumn {
  id       Int     @id @default(autoincrement())
  boardId  Int
  name     String  @db.VarChar(120)
  order    Int
  wipLimit Int?
  isDone   Boolean @default(false) // marca a coluna terminal (conclusão)
  board    Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@index([boardId])
  @@map("TB_BOARD_COLUMN")
}

model Task {
  id          Int          @id @default(autoincrement())
  companyId   Int
  projectId   Int
  columnId    Int
  number      Int // sequencial por projeto -> "GAV-42"
  title       String       @db.VarChar(255)
  description String?      @db.Text
  objective   String?      @db.Text // objetivo (entrada do fluxo)
  acceptance  String?      @db.Text // critério de aceite (ponto de aceitação)
  parentId    Int?
  assigneeId  Int?
  type        TaskType     @default(FEATURE)
  priority    TaskPriority @default(MEDIUM)
  estimateMd  Float? // estimativa em homem-dia
  rank        String       @db.VarChar(64) // ordenação lexicográfica no kanban
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @updatedAt
  deletedAt   DateTime?
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column      BoardColumn  @relation(fields: [columnId], references: [id])
  parent      Task?        @relation("Subtasks", fields: [parentId], references: [id])
  subtasks    Task[]       @relation("Subtasks")
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  labels      Label[]      @relation("TaskLabels")
  comments    Comment[]
  documents   Document[]
  checklist   TaskChecklist[]
  blocking    TaskDependency[] @relation("Blocker")
  blockedBy   TaskDependency[] @relation("Blocked")

  @@unique([projectId, number])
  @@index([companyId])
  @@index([columnId])
  @@map("TB_TASK")
}

enum MembershipRole {
  OWNER
  MANAGER
  TECH_LEAD
  DEV
  VIEWER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  FEATURE
  BUG
  TECH_DEBT
  IMPROVEMENT
  CHORE
}

enum CommentType {
  COMMENT
  CODE_REVIEW
  COMMIT_REF
  DEPLOY_LOG
}

enum DocType {
  SPEC
  PLAN
  NOTES
  ADR
  OTHER
}

model Label {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String   @db.VarChar(60)
  color     String?  @db.VarChar(20)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks     Task[]   @relation("TaskLabels")

  @@unique([companyId, name])
  @@index([companyId])
  @@map("TB_LABEL")
}

model Document {
  id        Int       @id @default(autoincrement())
  companyId Int
  title     String    @db.VarChar(200)
  body      String    @db.LongText // markdown
  type      DocType   @default(SPEC)
  version   Int       @default(1)
  projectId Int?
  taskId    Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([projectId])
  @@index([taskId])
  @@map("TB_DOCUMENT")
}

model TaskChecklist {
  id        Int      @id @default(autoincrement())
  taskId    Int
  title     String   @db.VarChar(255)
  checked   Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("TB_TASK_CHECKLIST")
}

model Comment {
  id          Int         @id @default(autoincrement())
  companyId   Int
  taskId      Int
  authorId    Int
  body        String      @db.Text
  type        CommentType @default(COMMENT)
  viaApiKeyId Int? // marca quando veio de um agente
  createdAt   DateTime    @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User     @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([companyId])
  @@index([taskId])
  @@map("TB_COMMENT")
}

// Aresta de precedência do fluxo: blocker precisa concluir antes de blocked.
model TaskDependency {
  id        Int      @id @default(autoincrement())
  companyId Int
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  blocker   Task     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Task     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([companyId])
  @@map("TB_TASK_DEPENDENCY")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  companyId   Int
  actorUserId Int
  viaApiKeyId Int?
  entityType  String   @db.VarChar(40)
  entityId    Int
  action      String   @db.VarChar(60)
  changes     Json?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("TB_ACTIVITY_LOG")
}

model Webhook {
  id        Int      @id @default(autoincrement())
  companyId Int
  url       String   @db.VarChar(500)
  secret    String?  @db.VarChar(120)
  events    Json? // ex.: ["task.created","task.moved"]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("TB_WEBHOOK")
}

// Idempotência de criações (ex.: POST /tasks/bulk com Idempotency-Key).
model IdempotencyKey {
  id        Int      @id @default(autoincrement())
  companyId Int
  key       String   @db.VarChar(120)
  response  Json?
  createdAt DateTime @default(now())

  @@unique([companyId, key])
  @@map("TB_IDEMPOTENCY_KEY")
}

// ---- Módulo de Estudos ----

enum StudyPlanStatus {
  PLANEJADO
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
  ABANDONADO
}

enum StudyTopicStatus {
  PENDENTE
  ESTUDANDO
  REVISAO
  CONCLUIDO
  PULADO
}

enum StudyCategory {
  LINGUAGEM
  FRAMEWORK
  CERTIFICACAO
  CONCEITO
  CURSO
  LIVRO
}

model StudyPlan {
  id          Int             @id @default(autoincrement())
  companyId   Int
  userId      Int
  title       String          @db.VarChar(200)
  description String?         @db.Text
  category    StudyCategory
  status      StudyPlanStatus @default(PLANEJADO)
  startDate   DateTime?
  targetDate  DateTime?
  resources   Json?
  projectId   Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime?       @updatedAt
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])
  topics      StudyTopic[]
  sessions    StudySession[]

  @@index([companyId])
  @@index([userId])
  @@map("TB_STUDY_PLAN")
}

model StudyTopic {
  id            Int              @id @default(autoincrement())
  planId        Int
  parentId      Int?
  title         String           @db.VarChar(200)
  description   String?          @db.Text
  sortOrder     Int              @default(0)
  status        StudyTopicStatus @default(PENDENTE)
  weight        Float            @default(1)
  estimateHours Float?
  loggedHours   Float            @default(0)
  notes         String?          @db.Text
  resources     Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime?        @updatedAt
  plan          StudyPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  parent        StudyTopic?      @relation("SubTopics", fields: [parentId], references: [id])
  children      StudyTopic[]     @relation("SubTopics")
  sessions      StudySession[]

  @@index([planId])
  @@index([parentId])
  @@map("TB_STUDY_TOPIC")
}

model StudySession {
  id          Int      @id @default(autoincrement())
  planId      Int
  topicId     Int
  startedAt   DateTime
  endedAt     DateTime?
  durationMin Int?
  notes       String?  @db.Text
  confidence  Int?     // 1 a 5
  createdAt   DateTime @default(now())
  plan        StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  topic       StudyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([topicId])
  @@map("TB_STUDY_SESSION")
}
