# Server
PORT=5000

# JWT
AT_SECRET=your_access_token_secret
RT_SECRET=your_refresh_token_secret
JWT_REFRESH_LIFETIME=7d
JWT_ACCESS_LIFETIME=1h
PERMIT_DOUBLE_SESSION=

# Database
DATABASE_URL=mysql://root:mydbpassword@localhost:3309/mydatabase
DB_USERNAME=appuser
DB_PASSWORD=mydbpassword
DB_DATABASE=mydatabase

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Google OAuth (optional - leave blank to disable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/accounts/google/redirect

# Frontend
FRONTEND_URL=http://localhost:4200

# Email / SMTP (used by the password-reset queue; leave blank to disable sending)
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
