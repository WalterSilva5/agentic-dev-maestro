# Variáveis lidas pelo docker-compose (copie para .env e ajuste se houver conflito de portas).
# Útil quando alguma porta padrão já está ocupada na máquina.

# Porta do host para a API (container expõe 5000 internamente)
API_PORT=5000
# Porta do host para o frontend (container expõe 80)
FRONT_PORT=4200
# Porta do host para o MySQL (container expõe 3306)
DB_PORT=3309
# Porta do host para o Redis
REDIS_PORT=6379

# Banco
DB_DATABASE=mydatabase
DB_USERNAME=appuser
DB_PASSWORD=mydbpassword

# Front (config.json gerado em runtime no container — configurável por ambiente)
# apiUrl: "/api" usa o proxy do nginx; troque por URL absoluta se a API estiver em outro host
FRONT_API_URL=/api
FRONT_PRODUCTION=true
APP_NAME=Agentic Dev Maestro
