{
  "name": "agentic-dev-maestro-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:dev": "ng serve --host 0.0.0.0 --allowed-hosts app.wsisys.com.br --configuration local",
    "start:local": "ng serve --watch --configuration local",
    "build": "ng build",
    "watch": "ng build --watch --configuration local && ng serve --configuration local",
    "test": "ng test",
    "serve:ssr:test": "node dist/test/server/server.mjs",
    "lint": "ng lint",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "build:android": "ng build --configuration production && npx cap sync android",
    "build:android:dev": "ng build --configuration local && npx cap sync android"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^20.3.1",
