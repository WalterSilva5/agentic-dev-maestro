{
  "name": "agentic-dev-maestro-backend",
  "version": "0.0.1",
  "description": "Backend NestJS do Agentic Dev Maestro",
  "author": "WalterSilva5",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "engines": {
    "npm": ">= 9.8.1",
    "node": ">=18.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist tsconfig.build.tsbuildinfo",
    "build": "nest build && tsc-alias -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/main.ts\"",
    "start:debug": "node -r tsconfig-paths/register -r ts-node/register src/main.ts",
    "start:prod": "node dist/main",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "lint": "prettier --write \"src/**/*.{ts,js,json}\" && eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "generate:module": "python ./module-generator/generate-module.py",
    "test": "jest --config ./test/jest.config.js --verbose=false --detectOpenHandles --maxWorkers=4",
    "test:watch": "jest --config ./test/jest.config.js --watch --maxWorkers=4",
    "test:cov": "jest --config ./test/jest.config.js --coverage --maxWorkers=2"
  },
  "dependencies": {
    "@nestjs/bull": "10.0.0",
    "@nestjs/cli": "8.2.8",
    "@nestjs/common": "8.0.0",
    "@nestjs/config": "2.1.0",
    "@nestjs/core": "8.0.0",
    "@nestjs/jwt": "8.0.1",
    "@nestjs/passport": "8.2.2",
    "@nestjs/platform-express": "8.0.0",
    "@nestjs/schedule": "3.0.3",
    "@nestjs/schematics": "8.0.2",
    "@nestjs/swagger": "6.1.3",
    "@prisma/client": "4.8.0",
    "bcrypt": "5.0.1",
    "bull": "4.11.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.13.2",
    "dataobject-parser": "1.2.22",
    "dotenv": "16.4.5",
    "nodemailer": "^7.0.12",
    "passport": "0.6.0",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "4.0.0",
    "passport-local": "1.0.0",
    "prisma": "4.8.0",
    "prisma-pagination": "0.2.3",
    "reflect-metadata": "0.1.13",
    "rimraf": "3.0.2",
    "rxjs": "7.2.0",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@faker-js/faker": "7.6.0",
    "@nestjs/testing": "8.2.1",
    "@types/bcrypt": "5.0.0",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.11",
    "@types/node": "16.18.38",
    "@types/nodemailer": "^7.0.5",
    "@types/passport": "1.0.17",
    "@types/passport-google-oauth20": "2.0.11",
    "@types/passport-jwt": "3.0.6",
    "@types/passport-local": "1.0.34",
    "@types/supertest": "2.0.11",
    "@typescript-eslint/eslint-plugin": "5.52.1-alpha.1",
    "@typescript-eslint/parser": "5.52.1-alpha.1",
    "eslint": "8",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-import-helpers": "1.2.1",
    "eslint-plugin-prettier": "4.0.0",
    "jest": "29.7.0",
    "nodemon": "2.0.20",
    "prettier": "2.3.2",
    "source-map-support": "0.5.20",
    "supertest": "6.1.3",
    "ts-jest": "29.1.1",
    "tsc-alias": "1.8.10"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.(test|spec)\\.ts$",
    "transform": {
      ".+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "moduleNameMapper": {
      "src/(.*)$": "<rootDir>/src/$1"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
